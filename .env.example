# ===========================================
# INTERVIEWACE ENVIRONMENT VARIABLES
# ===========================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!
# ===========================================

# ===========================================
# FRONTEND (Dashboard)
# ===========================================
VITE_API_URL=http://localhost:3000
VITE_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxx
# Or leave empty if using custom auth

# ===========================================
# API (Vercel Serverless Functions)
# ===========================================
# Groq AI (free tier available at console.groq.com)
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxx

# Paystack (get from paystack.com/dashboard/developers)
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxx
PAYSTACK_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxxxxxx

# Frontend URL for CORS and callbacks
FRONTEND_URL=http://localhost:5173

# ===========================================
# DATABASE (Turso - Optional for production)
# ===========================================
# Sign up at console.turso.tech
TURSO_URL=libsql://your-db-name-your-org.turso.io
TURSO_AUTH_TOKEN=eyXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ===========================================
# AUTHENTICATION (Clerk - Optional)
# ===========================================
# Sign up at clerk.com
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxx
CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxx

# ===========================================
# SMTP (For emails - Optional)
# ===========================================
# For password reset, verification emails
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# ===========================================
# PRODUCTION DOMAINS
# ===========================================
# When deploying, update these to your actual domains
PRODUCTION_URL=https://interviewace.com
API_URL=https://api.interviewace.com
ADMIN_URL=https://admin.interviewace.com